# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Prowlarr API Key (found in Prowlarr > Settings > General > API Key)
PROWLARR_API_KEY=your_prowlarr_api_key_here
PROWLARR_URL=http://prowlarr:9696

# Whitelist of Telegram user IDs (comma-separated). Empty = open access.
ALLOWED_USER_IDS=123456789,987654321

# Anna's Archive URL (optional, leave empty to disable)
ANNA_ARCHIVE_URL=https://annas-archive.gd

# Torrent download path (for Prowlarr grab + watcher)
BOOKS_DOWNLOAD_PATH=/downloads/books
DOWNLOAD_TIMEOUT_MINUTES=15

# Local Bot API server (optional, required for files > 50 MB)
# Get API_ID and API_HASH from https://my.telegram.org
# Docker: use http://telegram-bot-api:8081 (service name)
# Local: use http://localhost:8081
LOCAL_API_SERVER=
LOCAL_API_ID=
LOCAL_API_HASH=

# SMTP (optional, for email/Kindle delivery)
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
